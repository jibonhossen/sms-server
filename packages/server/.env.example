# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://sms_gateway:sms_gateway_password@localhost:5432/sms_gateway

# SMS-Gate
SMS_GATE_CLOUD_URL=https://api.sms-gate.app/3rdparty/v1

# Security
API_KEY_SECRET=your-secret-key-change-in-production
WEBHOOK_SECRET=webhook-secret-change-in-production

# Queue
QUEUE_PROCESS_INTERVAL_MS=1000
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_MS=60000

# Health Check
HEALTH_CHECK_CRON=*/5 * * * *
DAILY_RESET_CRON=0 0 * * *
DEVICE_OFFLINE_THRESHOLD_MS=600000

# SIM Defaults
DEFAULT_DAILY_SMS_LIMIT=100
